  },
  "devDependencies": {
    "tree-sitter-cli": "^0.24.2"
  },
  "packageManager": "yarn@3.8.1+sha256.860bab3ca20acc0476b3229f4841674e62e15453bd8f5dc8d0fea399edd235b6"
}
