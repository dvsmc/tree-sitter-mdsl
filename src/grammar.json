{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "mdsl",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "block"
      }
    },
    "_block_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "block"
        },
        {
          "type": "SYMBOL",
          "name": "sequence_block"
        },
        {
          "type": "SYMBOL",
          "name": "lotto_block"
        },
        {
          "type": "SYMBOL",
          "name": "condition"
        },
        {
          "type": "SYMBOL",
          "name": "action"
        },
        {
          "type": "SYMBOL",
          "name": "expression"
        }
      ]
    },
    "block": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "keyword"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_block_statement"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "root"
        },
        {
          "type": "STRING",
          "value": "selector"
        },
        {
          "type": "STRING",
          "value": "action"
        },
        {
          "type": "STRING",
          "value": "condition"
        },
        {
          "type": "STRING",
          "value": "lotto"
        },
        {
          "type": "STRING",
          "value": "while"
        }
      ]
    },
    "sequence_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "sequence"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_block_statement"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "lotto_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "lotto"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "action"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "sequence": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "SYMBOL",
        "name": "sequence_block"
      }
    },
    "condition": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "condition"
        },
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": ","
                },
                {
                  "type": "FIELD",
                  "name": "parameter",
                  "content": {
                    "type": "SYMBOL",
                    "name": "string"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "action": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "action"
        },
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": ","
                },
                {
                  "type": "FIELD",
                  "name": "parameter",
                  "content": {
                    "type": "SYMBOL",
                    "name": "string"
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "string": {
      "type": "PATTERN",
      "value": "\"(\\\\.|[^\"\\\\])*\""
    },
    "expression": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "PATTERN",
          "value": "\\d+"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [
    [
      "keyword",
      "lotto_block"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": []
}
